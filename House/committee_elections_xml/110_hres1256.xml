	<resolution-body id="H9F2399E0570F41469154842EBC60B500" style="traditional">
		<section display-inline="yes-display-inline" id="HE7202D01059F48240021E16386CF25F8" section-type="undesignated-section"><enum></enum><text>That the following named Members be,
			 and are hereby, elected to the following standing committees of the House of
			 Representatives:</text>
			<paragraph id="HF64A851D3DC245AC856FA438120900B8"><enum>(1)</enum><header>Committee on
			 Agriculture</header><text>Mr. Childers.</text>
			</paragraph><paragraph id="HBB76D9D8C5B3415B87D84BFBBE03EA14"><enum>(2)</enum><header>Committee on
			 Energy and Commerce</header><text>Ms. Matsui.</text>
			</paragraph><paragraph id="H4AE5B9CB29604CFBAC65E138E55E2650"><enum>(3)</enum><header>Committee on
			 Financial Services</header><text>Ms. Speier, Mr. Cazayoux, Mr. Childers.</text>
			</paragraph><paragraph id="HB42498C4599445B5B8BAFD046100CD1B"><enum>(4)</enum><header>Committee on
			 Science and Technology</header><text>Mr. Carson.</text>
			</paragraph><paragraph id="HE3108C419B8148FCA79894D74BBAEBEA"><enum>(5)</enum><header>Committee on
			 Veterans’ Affairs</header><text>Mr. Cazayoux.</text>
			</paragraph></section></resolution-body>
