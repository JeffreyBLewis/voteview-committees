<resolution-body style="traditional" id="H182004E5F4194325B83399F5FE66A2B0"> 
<section display-inline="yes-display-inline" section-type="undesignated-section" id="HFA15F75B41FF470684125B728055ACF4"><text>That the following named Members be and are hereby elected to the following standing committees of the House of Representatives:</text> 
<paragraph id="H50D05FC151AF4F16A63D1FDCB43CB6D0" display-inline="no-display-inline"><enum>(1)</enum><header>Committee on House Administration</header><text display-inline="yes-display-inline">Ms. Zoe Lofgren of California, Mr. Capuano, Mr. Gonzalez, Mrs. Davis of California, Mr. Davis of Alabama.</text></paragraph> 
<paragraph id="H7E328EDF8527479BABB38664237C0047" display-inline="no-display-inline"><enum>(2)</enum><header>Committee on Rules</header><text display-inline="yes-display-inline">Mr. Perlmutter, Ms. Pingree of Maine, Mr. Polis of Colorado.</text></paragraph> </section>
<section id="HAAD2C9E4DD3D4604ADC3F42E543C3E00" indent="up1"><enum>2.</enum><text display-inline="yes-display-inline">Paragraph (5) of House Resolution 24, One Hundred Eleventh Congress, agreed to January 7, 2009, is amended by striking <quote>Mr. Bishop of Utah,</quote> and inserting <quote>Mr. Bishop of New York,</quote>.</text></section> 
</resolution-body> 
<attestation><attestation-group><attestor display="no">Lorraine C. Miller,</attestor><role>Clerk.</role></attestation-group></attestation>
</resolution> 
