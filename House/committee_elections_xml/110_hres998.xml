	<resolution-body id="H0972F764ED5749FFAA2C4E49415DD972" style="traditional">
		<section display-inline="yes-display-inline" id="H808F892C02B548DCB8D13B54F66BFB59" section-type="undesignated-section"><enum></enum><text display-inline="yes-display-inline">That the following named Members be, and
			 are hereby, elected to the following standing committees of the House of
			 Representatives:</text>
			<committee-appointment-paragraph><header><committee-name committee-id="HAP00"> Committee on
			 Appropriations:</committee-name></header><text>Mr. Bonner of Alabama.</text>
			</committee-appointment-paragraph><committee-appointment-paragraph><header><committee-name committee-id="HBU00"> Committee on the
			 Budget</committee-name>:</header><text>Mr. Jordan of Ohio.</text>
			</committee-appointment-paragraph><committee-appointment-paragraph><header><committee-name committee-id="HBA00"> Committee on Financial
			 Services:</committee-name></header><text>Mr. Heller of Nevada.</text>
			</committee-appointment-paragraph><committee-appointment-paragraph><header><committee-name committee-id="HII00"> Committee on Natural
			 Resources:</committee-name></header><text>Mr. Smith of Nebraska and Mr. Wittman
			 of Virginia.</text>
			</committee-appointment-paragraph><committee-appointment-paragraph><header><committee-name committee-id="HPW00"> Committee on Transportation and
			 Infrastructure:</committee-name></header><text>Mr. Latta.</text>
			</committee-appointment-paragraph></section></resolution-body>
